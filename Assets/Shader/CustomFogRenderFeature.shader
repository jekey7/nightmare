        Tags { "RenderType"="Opaque" "RenderPipeline" = "UniversalPipeline" }
        LOD 100
        ZWrite Off ZTest Always

        Pass
        {
            Name "CustomFogPass"

            HLSLPROGRAM
            #pragma vertex Vert
            #pragma fragment Frag

            #include "Packages/com.unity.render-pipelines.universal/ShaderLibrary/Core.hlsl"
            #include "Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareDepthTexture.hlsl"
            #include "Packages/com.unity.render-pipelines.core/Runtime/Utilities/Blit.hlsl"

            struct FogAttributes
            {
                uint vertexID : SV_VertexID;
                UNITY_VERTEX_INPUT_INSTANCE_ID
            };

            struct FogVaryings
            {
                float4 positionCS : SV_POSITION;
                float2 texcoord   : TEXCOORD0;
                UNITY_VERTEX_OUTPUT_STEREO
            };

            float4 _FogColor;
            float _FogDensity;
            float _FogOffset;

            float4 _FlashLightPos;       // КћРЧ ПљЕх СТЧЅ
            float4 _FlashLightColor;     // КћРЧ ЛіЛѓ
            float _FlashLightRange;      // КћРЧ ЙќРЇ
            float _FlashLightIntensity;  // КћРЧ А­ЕЕ

            FogVaryings Vert(FogAttributes input)
            {
                FogVaryings output;
                UNITY_SETUP_INSTANCE_ID(input);
                UNITY_INITIALIZE_VERTEX_OUTPUT_STEREO(output);

                float4 pos = GetFullScreenTriangleVertexPosition(input.vertexID);
                float2 uv  = GetFullScreenTriangleTexCoord(input.vertexID);

                output.positionCS = pos;
                output.texcoord   = uv;
                return output;
            }

            half4 Frag(FogVaryings input) : SV_Target
            {
                UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(input);
                
                float4 color = SAMPLE_TEXTURE2D(_BlitTexture, sampler_LinearClamp, input.texcoord);
                float depth = SampleSceneDepth(input.texcoord);
                float linearDepth = LinearEyeDepth(depth, _ZBufferParams);

                // [УпАЁЕШ ФкЕх 1] ЧіРч ЧШМПРЧ ЙрБт(Brightness)ИІ АшЛъЧеДЯДй.
                // MuzzleFlashДТ HDR ФУЗЏИІ ЛчПыЧЯЙЧЗЮ 1.0КИДй ШЮОР ЙрРК АЊРЛ АЁС§ДЯДй.
                float maxBrightness = max(color.r, max(color.g, color.b));

                // ЙрБтАЁ 1.0 ~ 3.0 РЬЛѓРЬИщ 'ЙпБЄУМ'ЗЮ РЮНФЧЯПЉ ИЖНКХЉИІ Л§МК (0~1 ЙќРЇ)
                // ЙрРЛМіЗЯ 1ПЁ АЁБюПіСќ
                float emissionMask = smoothstep(0.8, 3.0, maxBrightness);

                // 1. ПљЕх ЦїСіМЧ РчБИМК
                float3 worldPos = ComputeWorldSpacePosition(input.texcoord, depth, UNITY_MATRIX_I_VP);

                // 2. ОШАГ БтКЛ АшЛъ
                float fogDistance = max(0, linearDepth - _FogOffset);
                float fogFactor = exp2(-_FogDensity * fogDistance); 

                // [УпАЁЕШ ФкЕх 2] ЙпБЄУМРЯ АцПь ОШАГ ШПАњ СІАХ (FogFactorИІ 1ЗЮ А­СІ)
                // emissionMaskАЁ 1РЬИщ(ОЦСж ЙрРИИщ) fogFactorЕЕ 1РЬ ЕЧОю ОШАГАЁ ЛчЖѓСќ
                fogFactor = saturate(fogFactor + emissionMask);

                // 3. ЖѓРЬЦЎ ЛъЖѕ(Scattering) ШПАњ АшЛъ
                float distToLight = distance(worldPos, _FlashLightPos.xyz);
                
                float lightAtten = saturate(1.0 - (distToLight / _FlashLightRange));
                lightAtten = pow(lightAtten, 2.0); 

                // ЙрРК ЙАУМ РЇПЁДТ ЛъЖѕБЄЕЕ БЛРЬ БзИБ ЧЪПфАЁ ОјРИЙЧЗЮ ОрШ­НУХД (МБХУ ЛчЧз)
                float3 scattering = _FlashLightColor.rgb * _FlashLightIntensity * lightAtten * (1.0 - fogFactor) * (1.0 - emissionMask);

                // 4. УжСО ЛіЛѓ ЧеМК
                float3 finalFogColor = _FogColor.rgb + scattering;

                return half4(lerp(finalFogColor, color.rgb, saturate(fogFactor)), color.a);
            }
            ENDHLSL
        }
    }
